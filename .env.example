# ─── Database — Supabase (Mumbai region) ───────────────────────────────────
# Pooled connection (app runtime) + direct (migrations)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# ─── Auth.js (Phase 1) ─────────────────────────────────────────────────────
# Generate with: npx auth secret
AUTH_SECRET=""

# ─── Cloudflare R2 — object storage ────────────────────────────────────────
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_PUBLIC="aaro-images"     # product images (public)
R2_BUCKET_PRIVATE="aaro-proofs"    # payment proof screenshots (signed URLs)

# ─── Resend — transactional email ──────────────────────────────────────────
RESEND_API_KEY=""

# ─── Upstash — cache / rate-limit / async jobs ─────────────────────────────
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
QSTASH_TOKEN=""

# ─── SMS (Phase 2) — local BD aggregator for OTP & due reminders ───────────
SMS_API_KEY=""
SMS_SENDER_ID=""

# ─── Payments (Phase 2) — SSLCommerz ───────────────────────────────────────
SSLCOMMERZ_STORE_ID=""
SSLCOMMERZ_STORE_PASSWORD=""
