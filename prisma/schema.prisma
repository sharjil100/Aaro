// ============================================================================
//  Aaro — PostgreSQL schema (source of truth for Phase 1).
//  After setting DATABASE_URL (Supabase, Mumbai region), run:
//     npx prisma migrate dev --name init
//  The Phase-0 UI uses typed mock data in src/lib/data.ts that mirrors these
//  models, so wiring the DB is a drop-in replacement.
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL") // Supabase: pooler vs direct connection
}

// ---- enums ----------------------------------------------------------------

enum UserRole {
  customer
  seller
  admin
}

enum AdminRole {
  super_admin
  operations
  finance
  seller_manager
  product_moderator
  support
}

enum SellerStatus {
  active
  warning
  due_soon
  overdue
  paused
  suspended
}

enum VerificationLevel {
  unverified
  basic
  trusted
  top
}

enum ProductStatus {
  draft
  pending
  active
  rejected
  inactive
  out_of_stock
}

enum OrderStatus {
  pending
  accepted
  processing
  shipped
  delivered
  completed
  cancelled
  returned
  disputed
}

enum DueStatus {
  pending
  partial
  paid
  overdue
}

enum LedgerType {
  commission_due // + owed to Aaro
  payment        // - seller paid
  adjustment     // +/- manual
  penalty        // + penalty
  waiver         // - waived
}

enum PaymentProofStatus {
  submitted
  under_review
  approved
  rejected
}

// ---- users & auth ---------------------------------------------------------

model User {
  id        String   @id @default(cuid())
  name      String
  email     String?  @unique
  phone     String?  @unique
  password  String? // hashed; null for OAuth
  role      UserRole @default(customer)
  adminRole AdminRole?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customerProfile CustomerProfile?
  seller          Seller?
  addresses       Address[]
  orders          Order[]
  reviews         Review[]
  notifications   Notification[]
  auditLogs       AdminAuditLog[]
}

model CustomerProfile {
  id     String  @id @default(cuid())
  userId String  @unique
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  avatar String?
}

model Address {
  id        String  @id @default(cuid())
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  label     String?
  recipient String
  phone     String
  line      String
  city      String
  area      String?
  isDefault Boolean @default(false)
}

// ---- sellers --------------------------------------------------------------

model Seller {
  id             String            @id @default(cuid())
  userId         String            @unique
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  slug           String            @unique
  shopName       String
  ownerName      String
  phone          String
  city           String
  address        String?
  status         SellerStatus      @default(active)
  verification   VerificationLevel @default(unverified)
  approved       Boolean           @default(false)
  commissionRate Decimal           @default(7) @db.Decimal(5, 2) // percent
  creditLimit    Decimal           @default(500) @db.Decimal(12, 2)
  dueOutstanding Decimal           @default(0) @db.Decimal(12, 2) // cached; ledger is truth
  rating         Decimal           @default(0) @db.Decimal(3, 2)
  ratingCount    Int               @default(0)
  responseRate   Int               @default(0)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  socialLinks   SellerSocialLink[]
  statusHistory SellerStatusHistory[]
  products      Product[]
  orders        Order[]
  ledger        LedgerEntry[]
  dues          SellerDue[]
  payments      SellerDuePayment[]

  @@index([status])
}

model SellerSocialLink {
  id       String @id @default(cuid())
  sellerId String
  seller   Seller @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  platform String // facebook | instagram | tiktok | website
  url      String
}

model SellerStatusHistory {
  id        String       @id @default(cuid())
  sellerId  String
  seller    Seller       @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  from      SellerStatus
  to        SellerStatus
  reason    String?
  createdAt DateTime     @default(now())
}

// ---- catalogue ------------------------------------------------------------

model Category {
  id        String     @id @default(cuid())
  slug      String     @unique
  name      String
  icon      String?
  parentId  String?
  parent    Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryTree")
  products  Product[]
}

model Product {
  id            String        @id @default(cuid())
  slug          String        @unique
  title         String
  description   String?
  sellerId      String
  seller        Seller        @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  categoryId    String
  category      Category      @relation(fields: [categoryId], references: [id])
  price         Decimal       @db.Decimal(12, 2)
  discountPrice Decimal?      @db.Decimal(12, 2)
  stock         Int           @default(0)
  status        ProductStatus @default(pending)
  codAvailable  Boolean       @default(true)
  freeDelivery  Boolean       @default(false)
  deliveryDays  String?
  rating        Decimal       @default(0) @db.Decimal(3, 2)
  ratingCount   Int           @default(0)
  sold          Int           @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  images   ProductImage[]
  variants ProductVariant[]
  reviews  Review[]
  orderItems OrderItem[]

  @@index([categoryId])
  @@index([sellerId])
  @@index([status])
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  position  Int     @default(0)
}

model ProductVariant {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  name      String // e.g. "Size", "Color"
  value     String // e.g. "M", "Red"
  sku       String?
  stock     Int     @default(0)
}

// ---- orders ---------------------------------------------------------------

model Order {
  id         String      @id @default(cuid())
  code       String      @unique
  customerId String
  customer   User        @relation(fields: [customerId], references: [id])
  sellerId   String
  seller     Seller      @relation(fields: [sellerId], references: [id])
  status     OrderStatus @default(pending)
  subtotal   Decimal     @db.Decimal(12, 2)
  deliveryFee Decimal    @default(0) @db.Decimal(12, 2)
  total      Decimal     @db.Decimal(12, 2)
  address    String
  phone      String
  notes      String?
  deliveredAt DateTime?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  items         OrderItem[]
  statusHistory OrderStatusHistory[]
  due           SellerDue?

  @@index([sellerId])
  @@index([status])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  title     String
  qty       Int
  unitPrice Decimal @db.Decimal(12, 2)
}

model OrderStatusHistory {
  id        String      @id @default(cuid())
  orderId   String
  order     Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status    OrderStatus
  note      String?
  createdAt DateTime    @default(now())
}

// ---- commission, dues & ledger (the heart of Aaro) ------------------------

model CommissionRule {
  id         String   @id @default(cuid())
  scope      String // global | category | seller | campaign
  refId      String? // category/seller id when scoped
  rate       Decimal  @db.Decimal(5, 2)
  createdAt  DateTime @default(now())
}

// One due per delivered order (idempotent). The ledger below is the audit trail.
model SellerDue {
  id               String    @id @default(cuid())
  sellerId         String
  seller           Seller    @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  orderId          String    @unique
  order            Order     @relation(fields: [orderId], references: [id])
  orderAmount      Decimal   @db.Decimal(12, 2)
  commissionRate   Decimal   @db.Decimal(5, 2)
  commissionAmount Decimal   @db.Decimal(12, 2)
  paidAmount       Decimal   @default(0) @db.Decimal(12, 2)
  status           DueStatus @default(pending)
  createdAt        DateTime  @default(now())
  deadlineAt       DateTime
  overdueAt        DateTime?

  @@index([sellerId, status])
}

// Append-only money ledger — never mutate; balances are derived.
model LedgerEntry {
  id        String     @id @default(cuid())
  sellerId  String
  seller    Seller     @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  type      LedgerType
  amount    Decimal    @db.Decimal(12, 2) // signed
  refType   String? // order | payment | adjustment
  refId     String?
  note      String?
  createdAt DateTime   @default(now())

  @@index([sellerId])
}

model SellerDuePayment {
  id        String             @id @default(cuid())
  sellerId  String
  seller    Seller             @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  amount    Decimal            @db.Decimal(12, 2)
  method    String // bkash | nagad | bank
  txnId     String?
  status    PaymentProofStatus @default(submitted)
  reviewedBy String?
  createdAt DateTime           @default(now())

  proof PaymentProof?
}

model PaymentProof {
  id        String           @id @default(cuid())
  paymentId String           @unique
  payment   SellerDuePayment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  imageUrl  String // private R2 bucket; served via signed URL
  note      String?
  createdAt DateTime         @default(now())
}

// ---- trust, support & system ----------------------------------------------

model Review {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  @@index([productId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  body      String?
  type      String
  readAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId, readAt])
}

model AdminAuditLog {
  id        String   @id @default(cuid())
  adminId   String
  admin     User     @relation(fields: [adminId], references: [id])
  action    String
  targetType String
  targetId  String?
  meta      Json?
  createdAt DateTime @default(now())

  @@index([adminId])
}

model SystemSetting {
  key   String @id
  value Json
}
